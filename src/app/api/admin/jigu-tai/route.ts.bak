import { NextRequest, NextResponse } from "next/server";
import { generateUniqueSlug } from "@/lib/article-slug";
import { createArticleWithTags } from "@/lib/tag-service";
import { logAdminAction } from "@/lib/admin-log";
import { callLlmDetailed } from "@/lib/llm-service";
import { JIGU_IMPORT_PROMPT_VERSION } from "@/lib/prompts";

interface SourceCandidate {
  id: string;
  title: string;
  url: string;
  source: "wikisource" | "gushiwen" | "shicimingju" | "wenxue100" | "guoxue";
  excerpt: string;
  body: string;
  confidence: number;
  script: "zh-Hans" | "source-original";
  label: string;
}

export async function POST(request: NextRequest) {
  try {
    const { title, sourceCandidate } = await request.json();

    if (!title || !title.trim()) {
      return NextResponse.json({ error: "请输入标题" }, { status: 400 });
    }

    const trimmedTitle = title.trim();
    const selectedSource = await normalizeSourceCandidate(sourceCandidate);

    if (!selectedSource) {
      const candidates = await searchJiguSources(trimmedTitle);
      return NextResponse.json({
        needSource: true,
        title: trimmedTitle,
        candidates,
        message: candidates.length > 0
          ? "请先确认原文来源。导入待校后，可在编辑页基于来源证据执行 AI 补全。"
          : "未检索到可靠来源，请人工补充原文或更换标题。",
      });
    }

    const baseTags = ["辑古台", "待AI增强"];
    const sourceConfidence = estimateJiguConfidence(selectedSource, 0);
    const article = await createArticleWithTags({
      data: {
        slug: await generateUniqueSlug(trimmedTitle),
        title: trimmedTitle,
        author: "佚名",
        source: "jigu",
        type: inferType(selectedSource.body, trimmedTitle),
        body: selectedSource.body,
        status: "review",
        tagList: JSON.stringify(baseTags),
        rawContent: JSON.stringify({
          sourceCandidate: selectedSource,
          evidenceStatus: "confirmed",
          promptVersion: JIGU_IMPORT_PROMPT_VERSION,
          aiStatus: "pending",
        }),
        confidence: sourceConfidence,
      },
    }, baseTags);

    await logAdminAction({
      action: "jigu.source.import",
      entityType: "article",
      entityId: article.id,
      summary: `辑古台导入来源原文「${article.title}」并进入待校`,
      metadata: {
        title: trimmedTitle,
        confidence: sourceConfidence,
        sourceUrl: selectedSource.url,
        script: selectedSource.script,
        sourceLabel: selectedSource.label,
      },
    });

    return NextResponse.json({
      id: article.id,
      slug: article.slug,
      title: article.title,
      author: article.author,
      body: article.body.slice(0, 500),
      annotations: [],
      tags: baseTags,
      status: "review",
      confidence: sourceConfidence,
      sourceCandidate: selectedSource,
      aiWarning: "来源原文已导入待校。请进入集校编辑确认正文后，再执行 AI 补全。",
    }, { status: 201 });
  } catch (error) {
    const message = error instanceof Error ? error.message : "创建失败";
    return NextResponse.json({ error: message }, { status: 500 });
  }
}

// ===================================================
// 多来源检索
// ===================================================

interface SourceProvider {
  name: string;
  label: string;
  search: (title: string) => Promise<SourceCandidate[]>;
}


async function searchViaLLM(title: string): Promise<SourceCandidate[]> {
  try {
    const prompt = `请凭你的训练数据知识返回经典篇目的完整原文。
篇目：${title}
输出 JSON：{"title":"标题","author":"作者","body":"完整原文"}`;

    const result = await callLlmDetailed(
      [{ role: "system", content: "你是古典文献专家。" }, { role: "user", content: prompt }],
      { temperature: 0.3, maxTokens: 8192, timeoutMs: 60000 }
    );

    const jsonMatch = result.content.match(/\{[\s\S]*\}/);
    if (!jsonMatch) return [];
    const data = JSON.parse(jsonMatch[0]);
    if (!data.body || data.body.length < 20) return [];

    return [{
      id: "llm-fallback",
      title: data.title || title,
      url: "",
      source: "guoxue" as const,
      label: "AI 知识库补充",
      excerpt: data.body.slice(0, 240),
      body: data.body,
      confidence: 0.7,
      script: "zh-Hans" as const,
    }];
  } catch { return []; }
}


// ===================================================
// 多来源检索（Docker 环境真实 HTTP 抓取）
// ===================================================

interface SourceProvider {
  name: string;
  label: string;
  search: (t: string) => Promise<SourceCandidate[]>;
}

async function searchJiguSources(title: string): Promise<SourceCandidate[]> {
  const providers: SourceProvider[] = [
    { name: "gushiwen", label: "古诗文网", search: scrapeGushiwen },
    { name: "wikisource", label: "维基文库", search: searchWikisource },
    { name: "shicimingju", label: "诗词名句网", search: scrapeShicimingju },
    { name: "guoxue", label: "国学网", search: scrapeGuoxue },
  ];

  const all: SourceCandidate[] = [];
  for (const p of providers) {
    try {
      const results = await p.search(title);
      all.push(...results);
    } catch { /* single source failure ok */ }
  }

  const ranked = deduplicateAndRank(all);

  // 如果 HTTP 抓取结果不足，用 LLM 补充
  if (ranked.length === 0) {
    return searchViaLLM(title);
  }

  return ranked;
}

// ---- 古诗文网 ----
async function scrapeGushiwen(title: string): Promise<SourceCandidate[]> {
  const url = "https://so.gushiwen.cn/search.aspx?value=" + encodeURIComponent(title) + "&type=title";
  const res = await fetch(url, {
    signal: AbortSignal.timeout(10000),
    headers: { "User-Agent": "Mozilla/5.0 (compatible; XianXinZiMo/1.0)" },
  });
  if (!res.ok) return [];
  const html = await res.text();

  const results: SourceCandidate[] = [];
  const linkRe = /<a[^>]*href="(\/shiwenv_[^"]+)"[^>]*>\s*<b>([^<]+)<\/b>/gi;
  let match, idx = 0;
  const seen = new Set<string>();

  while ((match = linkRe.exec(html)) !== null && idx < 3) {
    const detailUrl = "https://so.gushiwen.cn" + match[1];
    if (seen.has(detailUrl)) continue;
    seen.add(detailUrl);
    const pageTitle = match[2].replace(/<[^>]+>/g, "").trim();
    const body = await fetchGushiwenBody(detailUrl);
    if (!body || body.length < 20) continue;

    results.push({
      id: "gushiwen-" + idx,
      title: pageTitle || title,
      url: detailUrl,
      source: "gushiwen",
      label: "古诗文网",
      excerpt: body.slice(0, 240),
      body,
      confidence: calcConf(title, pageTitle, 0.85),
      script: "zh-Hans",
    });
    idx++;
  }
  return results;
}

async function fetchGushiwenBody(url: string): Promise<string> {
  const res = await fetch(url, {
    signal: AbortSignal.timeout(8000),
    headers: { "User-Agent": "Mozilla/5.0" },
  });
  if (!res.ok) return "";
  const html = await res.text();
  const m = html.match(/<div[^>]*class="[^"]*contson[^"]*"[^>]*>([\s\S]*?)<\/div>/i);
  if (!m) return "";
  return m[1].replace(/<br\s*\/?>/gi, "\n").replace(/<[^>]+>/g, "").replace(/&nbsp;/g, " ").replace(/&amp;/g, "&").replace(/&lt;/g, "<").replace(/&gt;/g, ">").replace(/&quot;/g, '"').trim();
}

// ---- 诗词名句网 ----
async function scrapeShicimingju(title: string): Promise<SourceCandidate[]> {
  const url = "https://www.shicimingju.com/chaxun/list/" + encodeURIComponent(title) + ".html";
  const res = await fetch(url, {
    signal: AbortSignal.timeout(10000),
    headers: { "User-Agent": "Mozilla/5.0" },
  });
  if (!res.ok) return [];
  const html = await res.text();

  const results: SourceCandidate[] = [];
  const blockRe = /<h3[^>]*><a[^>]*href="([^"]+)"[^>]*>([^<]+)<\/a><\/h3>\s*<div[^>]*class="[^"]*content[^"]*"[^>]*>([\s\S]*?)<\/div>/gi;
  let match, idx = 0;

  while ((match = blockRe.exec(html)) !== null && idx < 3) {
    const pageUrl = match[1].startsWith("http") ? match[1] : "https://www.shicimingju.com" + match[1];
    const pageTitle = match[2].trim();
    const body = match[3].replace(/<br\s*\/?>/gi, "\n").replace(/<[^>]+>/g, "").trim();
    if (!body || body.length < 15) continue;

    results.push({
      id: "shicimingju-" + idx,
      title: pageTitle || title,
      url: pageUrl,
      source: "shicimingju",
      label: "诗词名句网",
      excerpt: body.slice(0, 240),
      body,
      confidence: calcConf(title, pageTitle, 0.78),
      script: "zh-Hans",
    });
    idx++;
  }
  return results;
}

// ---- 国学网 ----
async function scrapeGuoxue(title: string): Promise<SourceCandidate[]> {
  const url = "http://www.guoxue.com/?s=" + encodeURIComponent(title);
  const res = await fetch(url, {
    signal: AbortSignal.timeout(8000),
    headers: { "User-Agent": "Mozilla/5.0" },
  });
  if (!res.ok) return [];
  const html = await res.text();

  const results: SourceCandidate[] = [];
  const entryRe = /<a[^>]*href="(https?:\/\/www\.guoxue\.com\/[^"]+)"[^>]*title="([^"]*)"[^>]*>/gi;
  let match, idx = 0;

  while ((match = entryRe.exec(html)) !== null && idx < 3) {
    const pageUrl = match[1], pageTitle = match[2].trim();
    if (!pageTitle.includes(title) && !title.includes(pageTitle)) continue;
    const body = await fetchGuoxueBody(pageUrl);
    if (!body || body.length < 20) continue;

    results.push({
      id: "guoxue-" + idx,
      title: pageTitle,
      url: pageUrl,
      source: "guoxue",
      label: "国学网",
      excerpt: body.slice(0, 240),
      body,
      confidence: calcConf(title, pageTitle, 0.72),
      script: "zh-Hans",
    });
    idx++;
  }
  return results;
}

async function fetchGuoxueBody(url: string): Promise<string> {
  const res = await fetch(url, {
    signal: AbortSignal.timeout(6000),
    headers: { "User-Agent": "Mozilla/5.0" },
  });
  if (!res.ok) return "";
  const html = await res.text();
  const m = html.match(/<article[^>]*>([\s\S]*?)<\/article>/i) || html.match(/<div[^>]*class="[^"]*content[^"]*"[^>]*>([\s\S]*?)<\/div>/i);
  if (!m) return "";
  return m[1].replace(/<br\s*\/?>/gi, "\n").replace(/<p[^>]*>/gi, "\n").replace(/<[^>]+>/g, "").replace(/&nbsp;/g, " ").replace(/&amp;/g, "&").trim();
}


// ---- 维基文库 ----
async function searchWikisource(title: string): Promise<SourceCandidate[]> {
  const searchUrl = new URL("https://zh.wikisource.org/w/api.php");
  searchUrl.searchParams.set("action", "opensearch");
  searchUrl.searchParams.set("search", title);
  searchUrl.searchParams.set("limit", "4");
  searchUrl.searchParams.set("namespace", "0");
  searchUrl.searchParams.set("format", "json");
  searchUrl.searchParams.set("origin", "*");

  try {
    const res = await fetch(searchUrl, { signal: AbortSignal.timeout(8000) });
    if (!res.ok) return [];
    const data = await res.json();
    const titles: string[] = Array.isArray(data?.[1]) ? data[1] : [];
    const urls: string[] = Array.isArray(data?.[3]) ? data[3] : [];

    const results: SourceCandidate[] = [];
    for (let idx = 0; idx < titles.length; idx++) {
      const pageTitle = titles[idx];
      const body = await fetchWikisourceExtract(pageTitle);
      if (!body || body.length < 20) continue;
      results.push({
        id: "wikisource-" + idx,
        title: pageTitle,
        url: withHansVariant(urls[idx] || "https://zh.wikisource.org/wiki/" + encodeURIComponent(pageTitle)),
        source: "wikisource",
        label: "维基文库",
        excerpt: body.slice(0, 240),
        body: cleanupSourceBody(body),
        confidence: calcConf(title, pageTitle, 0.78),
        script: "zh-Hans",
      });
    }
    return results;
  } catch {
    return [];
  }
}


function deduplicateAndRank(candidates: SourceCandidate[]): SourceCandidate[] {
  const seen = new Set<string>();
  return candidates
    .filter((c) => {
      const key = c.body.slice(0, 80);
      if (seen.has(key)) return false;
      seen.add(key);
      return true;
    })
    .sort((a, b) => b.confidence - a.confidence)
    .slice(0, 8);
}


async function fetchWikisourceExtract(title: string) {
  const url = new URL("https://zh.wikisource.org/w/api.php");
  url.searchParams.set("action", "query");
  url.searchParams.set("prop", "extracts");
  url.searchParams.set("explaintext", "1");
  url.searchParams.set("redirects", "1");
  url.searchParams.set("titles", title);
  url.searchParams.set("format", "json");
  url.searchParams.set("origin", "*");
  url.searchParams.set("variant", "zh-hans");

  const res = await fetch(url, { signal: AbortSignal.timeout(8000) });
  if (!res.ok) return "";
  const data = await res.json();
  const pages = data?.query?.pages || {};
  const page = Object.values(pages)[0] as { extract?: string } | undefined;
  return page?.extract || "";
}

function cleanupSourceBody(body: string) {
  const horizontalStart = body.indexOf("== 横排 ==");
  const content = horizontalStart >= 0 ? body.slice(horizontalStart + "== 横排 ==".length) : body;
  return content
    .replace(/^==\s*(竖排|横排)\s*==\s*$/gm, "")
    .replace(/\n{3,}/g, "\n\n")
    .replace(/^\s*本作品.*$/gm, "")
    .replace(/^\s*姊妹计划.*$/gm, "")
    .trim();
}

function calcConf(query: string, found: string, base: number): number {
  const q = query.replace(/[·\s]/g, ""), f = found.replace(/[·\s]/g, "");
  if (q === f) return Math.min(0.95, base + 0.15);
  if (f.includes(q) || q.includes(f)) return Math.min(0.9, base + 0.1);
  return base;
}


// ===================================================
// 辅助函数
// ===================================================

function calcConfidence(query: string, found: string, base: number): number {
  const q = query.replace(/[·\s]/g, "");
  const f = found.replace(/[·\s]/g, "");
  if (q === f) return Math.min(0.95, base + 0.15);
  if (f.includes(q) || q.includes(f)) return Math.min(0.9, base + 0.1);
  return base;
}


function withHansVariant(rawUrl: string) {
  const url = new URL(rawUrl);
  url.searchParams.set("variant", "zh-hans");
  return url.toString();
}

function estimateJiguConfidence(source: SourceCandidate, annotationCount: number) {
  const sourceScore = source.confidence || 0.6;
  const annotationScore = annotationCount > 5 ? 0.08 : annotationCount > 0 ? 0.04 : 0;
  return Math.min(0.95, Math.round((sourceScore + annotationScore) * 100) / 100);
}

function inferType(body: string, title: string): string {
  if (title.includes("词") || title.includes("令") || body.match(/^[^\n]{2,7}\n[^\n]{2,7}\n/m)) return "词";
  if (title.includes("曲") || title.includes("令") && body.includes("【")) return "曲";
  if (title.includes("赋") || title.includes("表") || title.includes("序") || title.includes("论")) return "文";
  if (body.length > 500) return "文";
  if (body.trim().split("\n").filter(Boolean).length <= 2) return "诗";
  return "文";
}

async function normalizeSourceCandidate(input: unknown): Promise<SourceCandidate | null> {
  if (!input || typeof input !== "object") return null;
  const data = input as Partial<SourceCandidate>;
  if (!data.title || !data.url || !data.body) return null;
  const simplifiedBody = await fetchWikisourceExtract(data.title).catch(() => "");
  const body = cleanupSourceBody(simplifiedBody || data.body);
  return {
    id: data.id || "manual-source",
    title: data.title,
    url: withHansVariant(data.url),
    source: data.source || "wikisource",
    label: data.label || "用户指定",
    excerpt: body.slice(0, 240),
    body,
    confidence: typeof data.confidence === "number" ? data.confidence : 0.7,
    script: simplifiedBody ? "zh-Hans" : "source-original",
  };
}

function withHansVariant(rawUrl: string) {
  const url = new URL(rawUrl);
  url.searchParams.set("variant", "zh-hans");
  return url.toString();
}

function estimateJiguConfidence(source: SourceCandidate, annotationCount: number) {
  const sourceScore = source.confidence || 0.6;
  const annotationScore = annotationCount > 5 ? 0.08 : annotationCount > 0 ? 0.04 : 0;
  return Math.min(0.95, Math.round((sourceScore + annotationScore) * 100) / 100);
}

function inferType(body: string, title: string): string {
  if (title.includes("词") || title.includes("令") || body.match(/^[^\n]{2,7}\n[^\n]{2,7}\n/m)) return "词";
  if (title.includes("曲") || title.includes("令") && body.includes("【")) return "曲";
  if (title.includes("赋") || title.includes("表") || title.includes("序") || title.includes("论")) return "文";
  if (body.length > 500) return "文";
  if (body.trim().split("\n").filter(Boolean).length <= 2) return "诗";
  return "文";
}
