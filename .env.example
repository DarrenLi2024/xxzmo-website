# ============================================================
# Database Configuration
# ============================================================
DATABASE_URL="file:./dev.db"

# ============================================================
# Site Configuration
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# Admin Authentication
# ============================================================
# SHA-256 hash of your admin password
# Generate with: node -e "console.log(require('crypto').createHash('sha256').update('your-password').digest('hex'))"
ADMIN_PASSWORD_HASH="your-hash-here"
# Secret used to sign admin login sessions. Must be at least 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET="your-random-jwt-secret-at-least-32-characters"

# ============================================================
# LLM Provider API Keys (REQUIRED)
# Obtain keys from respective provider platforms
# ============================================================

# DeepSeek API Key (https://platform.deepseek.com)
DEEPSEEK_API_KEY="sk-your-deepseek-key"

# Volcengine (火山引擎) API Key (https://console.volcengine.com)
VOLCENGINE_API_KEY="your-volcengine-key"

# MiniMax API Key (https://www.minimaxi.com)
MINIMAX_API_KEY="skcp-your-minimax-key"

# ============================================================
# Vercel Blob Storage (for painting/image uploads)
# ============================================================
# Get this from Vercel Dashboard → your project → Settings → Environment Variables
# or Vercel Storage → Blob → "Create Token"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
